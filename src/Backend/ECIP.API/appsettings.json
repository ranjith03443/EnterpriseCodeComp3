{
  "Application": {
    "Name": "Enterprise Code Intelligence Platform",
    "Version": "1.0.0",
    "Framework": ".NET 8",
    "Description": "AI-powered code comprehension platform for enterprise repositories"
  },
  "Api": {
    "BaseUrl": "https://localhost:7001",
    "Version": "1.0",
    "DefaultPageSize": 20,
    "MaxPageSize": 100
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "MinimumLevel": "Information",
    "EnableConsoleLogging": true,
    "EnableRequestLogging": true,
    "OutputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
  },
  "RepositorySettings": {
    "RootFolder": "workspace/repositories",
    "RepositoryRoot": "workspace/repositories",
    "IgnoredFolders": [
      ".git",
      "bin",
      "obj",
      "node_modules",
      ".vs",
      "packages"
    ],
    "MaximumFileSize": 5000000
  },
  "AiService": {
    "BaseUrl": "http://localhost:8000",
    "Enabled": true,
    "TimeoutSeconds": 30
  },
  "AllowedHosts": "*"
}
