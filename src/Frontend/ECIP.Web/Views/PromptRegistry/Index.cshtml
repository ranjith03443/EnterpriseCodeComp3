@using ECIP.Shared.DTOs.AI
@model List<PromptDto>
@{
    ViewData["Title"] = "Prompt Registry";
}

@if (!Model.Any())
{
    <div class="alert alert-warning d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>No prompts found. Ensure the AI Service is running and prompts YAML files are present in <code>src/Services/ECIP.AIService/registry/prompts/</code>.</div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-1 fw-bold text-primary">@Model.Count</div>
                <div class="text-muted small">Total Prompts</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-1 fw-bold text-success">@Model.SelectMany(p => p.Tags).Distinct().Count()</div>
                <div class="text-muted small">Unique Tags</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-1 fw-bold text-info">@Model.Select(p => p.Version).Distinct().Count()</div>
                <div class="text-muted small">Versions in Use</div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h5 class="fw-semibold mb-0"><i class="bi bi-journals me-2 text-primary"></i>Registered Prompts</h5>
            <span class="badge bg-primary">@Model.Count prompts</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Version</th>
                            <th>Description</th>
                            <th>Parameters</th>
                            <th>Tags</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prompt in Model)
                        {
                            <tr>
                                <td><code class="text-primary">@prompt.Name</code></td>
                                <td><span class="badge bg-secondary">v@prompt.Version</span></td>
                                <td class="text-muted">@prompt.Description</td>
                                <td>
                                    @foreach (var param in prompt.Parameters)
                                    {
                                        <span class="badge bg-light text-dark border me-1"><code>{@param}</code></span>
                                    }
                                </td>
                                <td>
                                    @foreach (var tag in prompt.Tags)
                                    {
                                        <span class="badge bg-info-subtle text-info me-1">@tag</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Detail" asp-route-name="@prompt.Name" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>Preview
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
