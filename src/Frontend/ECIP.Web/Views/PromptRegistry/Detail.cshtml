@using ECIP.Shared.DTOs.AI
@model PromptDetailDto
@{
    ViewData["Title"] = $"Prompt: {Model.Name}";
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Registry
    </a>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-bottom py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="fw-semibold mb-0"><i class="bi bi-file-text me-2 text-primary"></i><code>@Model.Name</code></h5>
            <span class="badge bg-secondary">v@Model.Version</span>
        </div>
    </div>
    <div class="card-body">
        <p class="text-muted mb-4">@Model.Description</p>
        <div class="row g-3 mb-4">
            <div class="col-auto">
                <span class="text-muted small fw-semibold">PARAMETERS</span>
                <div class="mt-1">
                    @foreach (var p in Model.Parameters)
                    {
                        <span class="badge bg-light text-dark border me-1"><code>{@p}</code></span>
                    }
                </div>
            </div>
            <div class="col-auto">
                <span class="text-muted small fw-semibold">TAGS</span>
                <div class="mt-1">
                    @foreach (var t in Model.Tags)
                    {
                        <span class="badge bg-info-subtle text-info me-1">@t</span>
                    }
                </div>
            </div>
        </div>
        <div>
            <span class="text-muted small fw-semibold">TEMPLATE</span>
            <pre class="bg-dark text-light rounded p-3 mt-2" style="font-size:0.85rem;white-space:pre-wrap;max-height:500px;overflow-y:auto;">@Model.Template</pre>
        </div>
    </div>
</div>
