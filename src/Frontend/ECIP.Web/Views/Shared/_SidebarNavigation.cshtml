@{
    var groups = new[]
    {
        new
        {
            Header = "",
            Items  = new[]
            {
                new { Controller = "Dashboard", Action = "Index", Label = "Dashboard", Icon = "bi-speedometer2" },
            }
        },
        new
        {
            Header = "REPOSITORY",
            Items  = new[]
            {
                new { Controller = "Repository",            Action = "Index", Label = "Manager",      Icon = "bi-box-seam" },
                new { Controller = "RepositoryIntelligence",Action = "Index", Label = "Intelligence", Icon = "bi-graph-up-arrow" },
            }
        },
        new
        {
            Header = "AI FEATURES",
            Items  = new[]
            {
                new { Controller = "Planner",       Action = "Index", Label = "Planner Agent",  Icon = "bi-robot" },
                new { Controller = "Architecture",  Action = "Index", Label = "Architecture",   Icon = "bi-diagram-3" },
                new { Controller = "FlowExplorer",  Action = "Index", Label = "Flow Explorer",  Icon = "bi-bezier2" },
                new { Controller = "KnowledgeGraph",Action = "Index", Label = "Knowledge Graph",Icon = "bi-graph-up" },
            }
        },
        new
        {
            Header = "DEVELOPER",
            Items  = new[]
            {
                new { Controller = "Onboarding",    Action = "Index", Label = "Onboarding",      Icon = "bi-person-badge" },
                new { Controller = "ImpactAnalysis",Action = "Index", Label = "Impact Analysis", Icon = "bi-shuffle" },
                new { Controller = "CodeGenerator", Action = "Index", Label = "Code Generator",  Icon = "bi-cpu" },
            }
        },
        new
        {
            Header = "SYSTEM",
            Items  = new[]
            {
                new { Controller = "PromptRegistry",Action = "Index", Label = "Prompts",  Icon = "bi-journals" },
                new { Controller = "Settings",      Action = "Index", Label = "Settings", Icon = "bi-gear" },
                new { Controller = "About",         Action = "Index", Label = "About",    Icon = "bi-info-circle" },
            }
        },
    };

    string CurrentController() =>
        ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<nav class="nav flex-column gap-0">
    @foreach (var group in groups)
    {
        @if (!string.IsNullOrEmpty(group.Header))
        {
            <div class="px-2 pt-3 pb-1" style="font-size:.65rem;letter-spacing:.08em;color:rgba(255,255,255,.35);font-weight:700">
                @group.Header
            </div>
        }
        @foreach (var item in group.Items)
        {
            var isActive = CurrentController().Equals(item.Controller, StringComparison.OrdinalIgnoreCase);
            <a class="nav-link py-1 px-2 rounded @(isActive ? "active" : "text-white-50")"
               style="font-size:.875rem"
               asp-controller="@item.Controller"
               asp-action="@item.Action">
                <i class="bi @item.Icon me-2" style="width:16px;display:inline-block;text-align:center"></i>@item.Label
            </a>
        }
    }
</nav>
