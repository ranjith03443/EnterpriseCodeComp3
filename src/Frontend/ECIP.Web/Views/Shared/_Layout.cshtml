<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ECIP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="d-flex flex-column min-vh-100">
        <header class="topbar shadow-sm">
            <div class="container-fluid px-4 py-3 d-flex justify-content-between align-items-center">
                <a class="navbar-brand fw-semibold text-white" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-diagram-3-fill me-2"></i>ECIP
                </a>
                <div class="d-flex align-items-center gap-3 text-white-50">
                    <span class="small">Enterprise Code Intelligence Platform</span>
                    <span class="badge bg-white text-primary">v1.0</span>
                </div>
            </div>
        </header>

        <div class="flex-grow-1">
            <div class="container-fluid px-0">
                <div class="row g-0 min-vh-100">
                    <aside class="col-lg-3 col-xl-2 sidebar p-4">
                        <div class="mb-4">
                            <h5 class="text-white-50 text-uppercase small fw-semibold">Navigation</h5>
                        </div>
                        <partial name="~/Views/Shared/_SidebarNavigation.cshtml" />
                    </aside>

                    <main class="col-lg-9 col-xl-10 p-4 p-lg-5 bg-light">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div>
                                <h2 class="h4 fw-semibold mb-1">@ViewData["Title"]</h2>
                                <p class="text-muted mb-0">Professional enterprise dashboard shell for ECIP.</p>
                            </div>
                        </div>
                        @RenderBody()
                    </main>
                </div>
            </div>
        </div>

        <footer class="border-top bg-white py-3">
            <div class="container-fluid px-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-center text-muted small">
                    <span>Enterprise Code Intelligence Platform</span>
                    <span>Version 1.0 • Built using .NET 8</span>
                </div>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
