@using ECIP.Shared.DTOs
@{
    ViewData["Title"] = "Flow Explorer";
    var repos      = ViewBag.Repositories as IReadOnlyList<ECIP.Core.Entities.RepositoryEntity> ?? [];
    var selectedId = ViewBag.SelectedId as Guid?;
    var flowView   = ViewBag.FlowView as FlowViewDto;
    var aiAvailable = (bool)(ViewBag.AiAvailable ?? false);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-bezier2 me-2 text-primary"></i>Flow Explorer</h1>
        <p class="text-muted mb-0">Visualise how requests, data, and AI queries flow through the architectural layers of your system.</p>
    </div>
</div>

@* Repository selector *@
<div class="card shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label fw-semibold mb-1">Repository</label>
                <select name="repositoryId" class="form-select" onchange="this.form.submit()">
                    <option value="">— Select a repository —</option>
                    @foreach (var r in repos)
                    {
                        if (selectedId == r.Id) { <option value="@r.Id" selected>@r.Name</option> }
                        else                    { <option value="@r.Id">@r.Name</option> }
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Explore</button>
            </div>
        </form>
    </div>
</div>

@if (selectedId.HasValue && flowView is null)
{
    <div class="alert alert-warning"><i class="bi bi-exclamation-triangle-fill me-2"></i>No flow data found. Please <a asp-controller="RepositoryIntelligence" asp-action="Index" asp-route-id="@selectedId">scan the repository</a> first.</div>
}

@if (flowView is not null)
{
    <div class="row g-2 mb-4">
        <div class="col-sm-4">
            <div class="card shadow-sm text-center"><div class="card-body"><div class="display-6 text-primary fw-bold">@flowView.Flows.Count</div><div class="text-muted small">Execution Flows</div></div></div>
        </div>
        <div class="col-sm-4">
            <div class="card shadow-sm text-center"><div class="card-body"><div class="display-6 text-success fw-bold">@flowView.Flows.Sum(f => f.Steps.Count)</div><div class="text-muted small">Total Steps</div></div></div>
        </div>
        <div class="col-sm-4">
            <div class="card shadow-sm text-center border-primary"><div class="card-body"><div class="small text-muted mb-1">Architecture Style</div><span class="badge bg-primary fs-6">@flowView.ArchitectureStyle</span></div></div>
        </div>
    </div>

    <div class="row g-4">
        @* Flow list sidebar *@
        <div class="col-lg-3">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold"><i class="bi bi-list-ul me-2"></i>Flows</div>
                <div class="list-group list-group-flush" id="flowList">
                    @foreach (var flow in flowView.Flows)
                    {
                        <button class="list-group-item list-group-item-action flow-btn" data-flow-id="@flow.Id">
                            <i class="bi @flow.Icon me-2 text-@flow.Color"></i>
                            <div>
                                <div class="fw-semibold small">@flow.Name</div>
                                <div class="text-muted" style="font-size:.75rem">@flow.Category</div>
                            </div>
                        </button>
                    }
                </div>
            </div>
        </div>

        @* Flow diagram *@
        <div class="col-lg-9">
            <div id="emptyFlow" class="card shadow-sm">
                <div class="card-body text-center py-5">
                    <i class="bi bi-bezier2 display-1 text-muted mb-3"></i>
                    <h5 class="text-muted">Select a Flow</h5>
                    <p class="text-muted mb-0">Choose an execution flow from the list to see its step-by-step diagram.</p>
                </div>
            </div>

            <div id="flowDiagram" class="d-none">
                <div class="card shadow-sm mb-3">
                    <div class="card-header d-flex align-items-center gap-2">
                        <i id="fIcon" class="bi text-primary"></i>
                        <span id="fName" class="fw-semibold"></span>
                        <span id="fCategory" class="badge bg-secondary ms-auto"></span>
                    </div>
                    <div class="card-body">
                        <p id="fDesc" class="text-muted small mb-3"></p>
                        <div id="fSteps"></div>
                    </div>
                </div>

                @* AI explain *@
                <div class="card shadow-sm">
                    <div class="card-header d-flex align-items-center gap-2">
                        <i class="bi bi-robot text-primary"></i>
                        <span class="fw-semibold">AI Flow Explanation</span>
                        @if (!aiAvailable) { <span class="badge bg-danger ms-auto">AI Offline</span> }
                    </div>
                    <div class="card-body">
                        <button id="explainBtn" class="btn btn-outline-primary @(!aiAvailable ? "disabled" : "")" @(!aiAvailable ? "disabled" : "")>
                            <i class="bi bi-stars me-2"></i>Explain this Flow with AI
                        </button>
                        <div id="explainLoading" class="d-none mt-3 text-center">
                            <div class="spinner-border spinner-border-sm text-primary me-2"></div>Generating explanation…
                        </div>
                        <div id="explainResult" class="mt-3 d-none">
                            <hr>
                            <div id="explainText" class="lh-lg small"></div>
                        </div>
                        <div id="explainError" class="alert alert-danger mt-3 d-none small"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else if (!selectedId.HasValue)
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-bezier2 display-1 text-muted mb-3"></i>
            <h5 class="text-muted">Select a Repository</h5>
            <p class="text-muted mb-0">Choose a repository above to explore its execution flows.</p>
        </div>
    </div>
}

@section Scripts {
<script>
(function () {
    const flows = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(flowView?.Flows ?? []));
    let currentFlow = null;

    function renderStep(step, isLast) {
        const comps = (step.components || []).map(c => `<span class="badge bg-light text-dark border me-1 mb-1">${c}</span>`).join('');
        const arrow = isLast ? '' : `<div class="text-center my-1"><i class="bi bi-arrow-down text-muted fs-5"></i></div>`;
        return `
            <div class="card border-${step.color} mb-0">
                <div class="card-body py-2 px-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="badge bg-${step.color} rounded-circle" style="width:24px;height:24px;line-height:16px;font-size:.75rem">${step.order}</span>
                        <i class="bi ${step.icon} text-${step.color}"></i>
                        <strong>${step.name}</strong>
                        <span class="badge bg-light text-dark border ms-auto small">${step.layer}</span>
                    </div>
                    <p class="text-muted small mb-1">${step.description}</p>
                    <div>${comps}</div>
                </div>
            </div>${arrow}`;
    }

    function showFlow(flowId) {
        const flow = flows.find(f => f.id === flowId);
        if (!flow) return;
        currentFlow = flow;

        document.getElementById('fIcon').className = `bi ${flow.icon} text-${flow.color}`;
        document.getElementById('fName').textContent = flow.name;
        document.getElementById('fCategory').textContent = flow.category;
        document.getElementById('fDesc').textContent = flow.description;
        document.getElementById('fSteps').innerHTML = flow.steps.map((s, i) => renderStep(s, i === flow.steps.length - 1)).join('');

        document.getElementById('emptyFlow').classList.add('d-none');
        document.getElementById('flowDiagram').classList.remove('d-none');

        document.getElementById('explainResult').classList.add('d-none');
        document.getElementById('explainError').classList.add('d-none');

        document.querySelectorAll('.flow-btn').forEach(b => b.classList.remove('active'));
        document.querySelector(`.flow-btn[data-flow-id="${flowId}"]`)?.classList.add('active');
    }

    document.querySelectorAll('.flow-btn').forEach(btn => {
        btn.addEventListener('click', () => showFlow(btn.dataset.flowId));
    });

    if (flows.length > 0) showFlow(flows[0].id);

    document.getElementById('explainBtn')?.addEventListener('click', async () => {
        if (!currentFlow) return;
        const context = `Flow: ${currentFlow.name}\nSteps: ${currentFlow.steps.map(s => `${s.order}. ${s.name} (${s.layer}): ${s.description}`).join('\n')}`;

        document.getElementById('explainBtn').disabled = true;
        document.getElementById('explainLoading').classList.remove('d-none');
        document.getElementById('explainResult').classList.add('d-none');
        document.getElementById('explainError').classList.add('d-none');

        try {
            const resp = await fetch('@Url.Action("ExplainFlow", "FlowExplorer")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ flowName: currentFlow.name, context }),
            });
            if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
            const plan = await resp.json();
            document.getElementById('explainText').textContent = plan.summary || 'No explanation available.';
            document.getElementById('explainResult').classList.remove('d-none');
        } catch (err) {
            document.getElementById('explainError').textContent = err.message;
            document.getElementById('explainError').classList.remove('d-none');
        } finally {
            document.getElementById('explainBtn').disabled = false;
            document.getElementById('explainLoading').classList.add('d-none');
        }
    });
})();
</script>
}
