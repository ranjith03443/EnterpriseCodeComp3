@model ECIP.Web.ViewModels.RepositoryIntelligenceViewModel
@{
    ViewData["Title"] = "Repository Intelligence";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-controller="Repository" asp-action="Index">Repositories</a></li>
        <li class="breadcrumb-item active" aria-current="page">Intelligence Dashboard</li>
    </ol>
</nav>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.HasData)
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body text-center py-5">
            <i class="bi bi-search display-1 text-muted"></i>
            <h4 class="mt-3">No Intelligence Data Available</h4>
            <p class="text-muted">Register a repository, activate it, and scan it to generate intelligence data.</p>
            <a asp-controller="Repository" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-box-seam me-1"></i> Go to Repository Manager
            </a>
        </div>
    </div>
}
else
{
    var d = Model.Dashboard!;

    <!-- Repository Header -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="fw-semibold mb-1"><i class="bi bi-diagram-3 me-2"></i>@d.RepositoryName</h4>
                    <span class="text-muted">@d.RepositoryType · @d.RepositoryRoot</span>
                </div>
                <div class="d-flex gap-2">
                    <a href="@Model.ExportJsonUrl" class="btn btn-outline-primary btn-sm" target="_blank">
                        <i class="bi bi-filetype-json me-1"></i>Export JSON
                    </a>
                    <a href="@Model.ExportCsvUrl" class="btn btn-outline-success btn-sm" target="_blank">
                        <i class="bi bi-filetype-csv me-1"></i>Export CSV
                    </a>
                    <span class="badge bg-success-subtle text-success align-self-center fs-6">@d.Status</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-tabs mb-4" id="intelligenceTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <a class="nav-link @(Model.ActiveTab == "overview" ? "active" : "")"
               asp-action="Index" asp-route-id="@Model.RepositoryId" asp-route-tab="overview">
                <i class="bi bi-speedometer2 me-1"></i>Overview
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link @(Model.ActiveTab == "statistics" ? "active" : "")"
               asp-action="Index" asp-route-id="@Model.RepositoryId" asp-route-tab="statistics">
                <i class="bi bi-bar-chart me-1"></i>Statistics
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link @(Model.ActiveTab == "projects" ? "active" : "")"
               asp-action="Index" asp-route-id="@Model.RepositoryId" asp-route-tab="projects">
                <i class="bi bi-folder2-open me-1"></i>Projects
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link @(Model.ActiveTab == "languages" ? "active" : "")"
               asp-action="Index" asp-route-id="@Model.RepositoryId" asp-route-tab="languages">
                <i class="bi bi-code-slash me-1"></i>Languages
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link @(Model.ActiveTab == "folders" ? "active" : "")"
               asp-action="Index" asp-route-id="@Model.RepositoryId" asp-route-tab="folders">
                <i class="bi bi-diagram-3 me-1"></i>Folders
            </a>
        </li>
        <li class="nav-item" role="presentation">
            <a class="nav-link @(Model.ActiveTab == "timeline" ? "active" : "")"
               asp-action="Index" asp-route-id="@Model.RepositoryId" asp-route-tab="timeline">
                <i class="bi bi-clock-history me-1"></i>Timeline
            </a>
        </li>
    </ul>

    <!-- Overview Tab -->
    @if (Model.ActiveTab == "overview")
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-files display-6 text-primary"></i>
                        <h3 class="fw-bold mt-2 mb-0">@d.TotalFiles</h3>
                        <small class="text-muted">Total Files</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-folder display-6 text-warning"></i>
                        <h3 class="fw-bold mt-2 mb-0">@d.TotalFolders</h3>
                        <small class="text-muted">Folders</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-box-seam display-6 text-success"></i>
                        <h3 class="fw-bold mt-2 mb-0">@d.ProjectCount</h3>
                        <small class="text-muted">Projects</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-code-slash display-6 text-info"></i>
                        <h3 class="fw-bold mt-2 mb-0">@d.LanguageCount</h3>
                        <small class="text-muted">Languages</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-hdd display-6 text-danger"></i>
                        <h3 class="fw-bold mt-2 mb-0">@d.RepositorySize</h3>
                        <small class="text-muted">Total Size</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-clock display-6 text-secondary"></i>
                        <h3 class="fw-bold mt-2 mb-0 fs-6">@(d.LastScanDate?.ToString("MM/dd HH:mm") ?? "Never")</h3>
                        <small class="text-muted">Last Scan</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-3"><i class="bi bi-pie-chart me-2"></i>Top Languages</h5>
                        @foreach (var lang in d.Languages.Take(8))
                        {
                            <div class="mb-2">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="fw-semibold">@lang.Language</span>
                                    <span class="text-muted">@lang.FileCount files · @lang.Percentage%</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar" role="progressbar" style="width: @lang.Percentage%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-3"><i class="bi bi-folder2-open me-2"></i>Discovered Projects</h5>
                        @if (d.Projects.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover align-middle mb-0">
                                    <thead><tr><th>Project</th><th>Type</th><th>Path</th></tr></thead>
                                    <tbody>
                                        @foreach (var p in d.Projects.Take(8))
                                        {
                                            <tr>
                                                <td class="fw-semibold">@p.Name</td>
                                                <td><span class="badge bg-primary-subtle text-primary">@p.ProjectType</span></td>
                                                <td class="text-muted small">@p.RelativePath</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No projects discovered yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Statistics Tab -->
    @if (Model.ActiveTab == "statistics")
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 text-center h-100">
                    <div class="card-body">
                        <h4 class="fw-bold text-primary">@d.TotalFiles</h4>
                        <small class="text-muted">Total Files</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 text-center h-100">
                    <div class="card-body">
                        <h4 class="fw-bold text-success">@d.SourceFiles</h4>
                        <small class="text-muted">Source Files</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 text-center h-100">
                    <div class="card-body">
                        <h4 class="fw-bold text-info">@d.ConfigurationFiles</h4>
                        <small class="text-muted">Config Files</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 text-center h-100">
                    <div class="card-body">
                        <h4 class="fw-bold text-warning">@d.DocumentationFiles</h4>
                        <small class="text-muted">Doc Files</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 text-center h-100">
                    <div class="card-body">
                        <h4 class="fw-bold text-secondary">@d.UnknownFiles</h4>
                        <small class="text-muted">Other Files</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm rounded-4 text-center h-100">
                    <div class="card-body">
                        <h4 class="fw-bold text-danger">@d.AverageFileSize</h4>
                        <small class="text-muted">Avg File Size</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">File Classification</h5>
                        @{
                            var totalF = d.TotalFiles > 0 ? d.TotalFiles : 1;
                            var srcPct = Math.Round((double)d.SourceFiles / totalF * 100, 1);
                            var cfgPct = Math.Round((double)d.ConfigurationFiles / totalF * 100, 1);
                            var docPct = Math.Round((double)d.DocumentationFiles / totalF * 100, 1);
                            var unkPct = Math.Round((double)d.UnknownFiles / totalF * 100, 1);
                        }
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Source Files</span><span>@d.SourceFiles (@srcPct%)</span>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar bg-success" style="width: @srcPct%"></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Configuration Files</span><span>@d.ConfigurationFiles (@cfgPct%)</span>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar bg-info" style="width: @cfgPct%"></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Documentation Files</span><span>@d.DocumentationFiles (@docPct%)</span>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar bg-warning" style="width: @docPct%"></div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between small mb-1">
                                <span>Other Files</span><span>@d.UnknownFiles (@unkPct%)</span>
                            </div>
                            <div class="progress" style="height: 10px;">
                                <div class="progress-bar bg-secondary" style="width: @unkPct%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-6">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body">
                        <h5 class="card-title mb-3">Size Information</h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item d-flex justify-content-between px-0">
                                Total Repository Size <span class="fw-semibold">@d.RepositorySize</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                Largest File <span class="fw-semibold">@d.LargestFileName</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                Largest File Size <span class="fw-semibold">@d.LargestFileSize</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                Average File Size <span class="fw-semibold">@d.AverageFileSize</span>
                            </li>
                            <li class="list-group-item d-flex justify-content-between px-0">
                                Total Folders <span class="fw-semibold">@d.TotalFolders</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Projects Tab -->
    @if (Model.ActiveTab == "projects")
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Discovered Projects (@d.Projects.Count)</h5>
                </div>

                <!-- Search and Filter -->
                <form method="get" class="row g-2 mb-3">
                    <input type="hidden" name="id" value="@Model.RepositoryId" />
                    <input type="hidden" name="tab" value="projects" />
                    <div class="col-md-4">
                        <input type="text" class="form-control form-control-sm" name="search" placeholder="Search projects..." value="@Model.SearchQuery" />
                    </div>
                    <div class="col-md-3">
                        <select class="form-select form-select-sm" name="filterProjectType">
                            <option value="">All Types</option>
                            @foreach (var type in d.Projects.Select(p => p.ProjectType).Distinct().OrderBy(t => t))
                            {
                                <option value="@type" selected="@(Model.FilterProjectType == type)">@type</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select form-select-sm" name="sortBy">
                            <option value="">Sort By</option>
                            <option value="name" selected="@(Model.SortBy == "name")">Name</option>
                            <option value="type" selected="@(Model.SortBy == "type")">Type</option>
                            <option value="path" selected="@(Model.SortBy == "path")">Path</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-funnel me-1"></i>Filter
                        </button>
                    </div>
                </form>

                @if (d.Projects.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Project Name</th>
                                    <th>Project Type</th>
                                    <th>File</th>
                                    <th>Location</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var project in d.Projects)
                                {
                                    <tr>
                                        <td class="fw-semibold">@project.Name</td>
                                        <td><span class="badge bg-primary-subtle text-primary">@project.ProjectType</span></td>
                                        <td><code>@project.FileName</code></td>
                                        <td class="text-muted small">@project.RelativePath</td>
                                        <td><span class="badge bg-success-subtle text-success">Discovered</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No projects match the current filter criteria.</p>
                }
            </div>
        </div>
    }

    <!-- Languages Tab -->
    @if (Model.ActiveTab == "languages")
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Language Distribution (@d.Languages.Count languages)</h5>
                    <form method="get" class="d-flex gap-2">
                        <input type="hidden" name="id" value="@Model.RepositoryId" />
                        <input type="hidden" name="tab" value="languages" />
                        <input type="text" class="form-control form-control-sm" name="filterLanguage" placeholder="Filter language..." value="@Model.FilterLanguage" style="width: 200px;" />
                        <button type="submit" class="btn btn-outline-primary btn-sm"><i class="bi bi-search"></i></button>
                    </form>
                </div>

                @if (d.Languages.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Language</th>
                                    <th>Extension</th>
                                    <th>Files</th>
                                    <th>Total Size</th>
                                    <th style="width: 30%">Percentage</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var lang in d.Languages)
                                {
                                    <tr>
                                        <td class="fw-semibold">@lang.Language</td>
                                        <td><code>@lang.Extension</code></td>
                                        <td>@lang.FileCount</td>
                                        <td>@lang.TotalSizeFormatted</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-grow-1" style="height: 10px;">
                                                    <div class="progress-bar" role="progressbar" style="width: @lang.Percentage%"></div>
                                                </div>
                                                <span class="small fw-semibold" style="min-width: 45px;">@lang.Percentage%</span>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No language data available.</p>
                }
            </div>
        </div>
    }

    <!-- Folders Tab -->
    @if (Model.ActiveTab == "folders")
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Folder Explorer (@d.Folders.Count folders)</h5>

                @if (d.Folders.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Folder</th>
                                    <th>Path</th>
                                    <th>Files</th>
                                    <th>Size</th>
                                    <th>Depth</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var folder in d.Folders.OrderBy(f => f.Depth).ThenBy(f => f.FolderName).Take(100))
                                {
                                    var indent = new string('\u00A0', folder.Depth * 3);
                                    <tr>
                                        <td>
                                            <span class="text-muted">@indent</span>
                                            <i class="bi bi-folder-fill text-warning me-1"></i>
                                            <span class="fw-semibold">@folder.FolderName</span>
                                        </td>
                                        <td class="text-muted small">@folder.RelativePath</td>
                                        <td><span class="badge bg-light text-dark">@folder.NumberOfFiles</span></td>
                                        <td>@folder.TotalSizeFormatted</td>
                                        <td><span class="badge bg-secondary-subtle text-secondary">Level @folder.Depth</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (d.Folders.Count > 100)
                    {
                        <p class="text-muted small mt-2">Showing top 100 of @d.Folders.Count folders.</p>
                    }
                }
                else
                {
                    <p class="text-muted">No folder data available. Scan the repository first.</p>
                }
            </div>
        </div>
    }

    <!-- Timeline Tab -->
    @if (Model.ActiveTab == "timeline")
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body">
                <h5 class="card-title mb-4"><i class="bi bi-clock-history me-2"></i>Scan History</h5>

                @if (d.Timeline.Any())
                {
                    <div class="position-relative ms-3">
                        <div class="position-absolute top-0 start-0 h-100 border-start border-2 border-primary" style="margin-left: 8px;"></div>
                        @foreach (var entry in d.Timeline)
                        {
                            <div class="d-flex mb-4 position-relative">
                                <div class="position-relative me-3">
                                    <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 18px; height: 18px;">
                                        <i class="bi bi-check text-white" style="font-size: 10px;"></i>
                                    </div>
                                </div>
                                <div class="card border-0 shadow-sm rounded-3 flex-grow-1">
                                    <div class="card-body py-3">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <h6 class="mb-0">Repository Scan</h6>
                                            <span class="badge bg-success">@entry.Status</span>
                                        </div>
                                        <div class="row g-2 small text-muted">
                                            <div class="col-md-3">
                                                <i class="bi bi-calendar me-1"></i>@entry.ScanDate.ToString("g")
                                            </div>
                                            <div class="col-md-2">
                                                <i class="bi bi-stopwatch me-1"></i>@entry.Duration
                                            </div>
                                            <div class="col-md-2">
                                                <i class="bi bi-files me-1"></i>@entry.FilesProcessed files
                                            </div>
                                            <div class="col-md-2">
                                                <i class="bi bi-folder me-1"></i>@entry.FoldersProcessed folders
                                            </div>
                                            <div class="col-md-3">
                                                <i class="bi bi-box-seam me-1"></i>@entry.ProjectsFound projects · @entry.LanguagesDetected languages
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted">No scan history available.</p>
                }
            </div>
        </div>
    }
}
